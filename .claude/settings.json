{
  "permissions": {
    "allow": [
      "Bash(Get-ChildItem *)",
      "Bash(Get-Content *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/guard_git_add.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/guard_state_files.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
